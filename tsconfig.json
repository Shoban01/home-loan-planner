{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["vitest/globals", "node"],
    "skipLibCheck": true
  },
  "include": ["src", "tests", "scripts"]
}
